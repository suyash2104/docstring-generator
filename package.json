{
  "name": "docstring-generator",
  "displayName": "AI Docstring Generator",
  "description": "Generate docstrings for functions using AI",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onLanguage:python"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docstringGenerator.generateDocstring",
        "title": "Generate Docstring"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "docstringGenerator.generateDocstring",
          "when": "editorTextFocus && resourceExtname == .py",
          "group": "1_modification"
        }
      ],
    "commandPalette": [
        {
          "command": "docstringGenerator.generateDocstring",
          "when": "editorLangId == python"
        }
      ]
    },
    "keybindings": [
      {
        "command": "docstringGenerator.generateDocstring",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus && editorLangId == python"
      }
    ],
    "configuration": {
      "title": "Docstring Generator",
      "properties": {
        "docstringGenerator.modelPath": {
          "type": "string",
          "default": "../models/",
          "description": "Path to store the AI model"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.102.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@huggingface/hub": "^2.4.1",
    "axios": "^1.11.0",
    "llama-cpp": "^1.0.0",
    "node-llama-cpp": "^3.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suyash2104/docstring-generator.git"
  },
  "license": "MIT"
}
